# --- Convex (written automatically by `npx convex dev`) ---
NEXT_PUBLIC_CONVEX_URL=

# --- Clerk (Clerk Dashboard → API Keys) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Note: CLERK_JWT_ISSUER_DOMAIN is NOT set here — set it as a Convex env var
# (Convex Dashboard → Settings → Environment Variables) to your Clerk Frontend API URL,
# e.g. https://your-app.clerk.accounts.dev

# --- Python AI service (apps/ai) ---
# Base URL of the FastAPI service (Tier 2 detectors: /score, /extract, /job-fit, /format, /region).
NEXT_PUBLIC_AI_URL=http://localhost:8000

# --- Tier 3 AI rewriting (Vercel AI SDK, multi-provider) ---
# Provider selection + optional model override (see lib/ai/rewriter.ts).
AI_PROVIDER=openai
# AI_MODEL=
# Set the API key for the provider you chose above (real keys go in .env.local, never committed):
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
