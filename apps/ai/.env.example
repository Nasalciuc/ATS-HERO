# ATS Hero AI service — environment (managed via Doppler in production)

# Comma-separated allowed CORS origins (the Next.js app).
ATS_AI_CORS_ORIGINS=["http://localhost:3000"]

# spaCy model name (falls back to a blank pipeline if unavailable).
ATS_AI_SPACY_MODEL=en_core_web_sm

# Max upload size in bytes (default 5 MB).
ATS_AI_MAX_UPLOAD_BYTES=5242880
