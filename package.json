{
  "name": "ats-hero",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"vite\" \"npm:server\"",
    "web": "vite",
    "server": "tsx watch server/index.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "figma:status": "node scripts/figma-status.mjs",
    "figma:download:desktop": "node scripts/download-figma-pages.mjs --section desktop --delay 10000",
    "figma:download:pages": "node scripts/download-figma-pages.mjs --section pages --delay 10000",
    "figma:download:rest": "node scripts/download-figma-pages.mjs --delay 10000",
    "figma:download:all": "node scripts/download-figma-pages.mjs --delay 10000",
    "api:health": "node scripts/api-smoke-test.mjs",
    "api:test": "node scripts/api-smoke-test.mjs",
    "postman:run": "npx --yes newman run postman/ATS-Hero-API.postman_collection.json -e postman/ATS-Hero-Local.postman_environment.json",
    "audit:screenshots": "node scripts/playwright-audit.mjs"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.3",
    "playwright": "^1.61.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
