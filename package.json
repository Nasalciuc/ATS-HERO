{
  "name": "ats-hero",
  "private": true,
  "version": "0.1.0",
  "description": "ATS Hero monorepo — Next.js web app, Python AI service, shared packages",
  "scripts": {
    "dev": "npm run dev --prefix apps/web",
    "dev:web": "npm run dev --prefix apps/web",
    "build": "npm run build --prefix apps/web",
    "build:web": "npm run build --prefix apps/web",
    "start": "npm run start --prefix apps/web",
    "test": "npm test --prefix apps/web",
    "figma:status": "node tools/scripts/figma-status.mjs",
    "figma:download:desktop": "node tools/scripts/download-figma-pages.mjs --section desktop --delay 10000",
    "figma:download:pages": "node tools/scripts/download-figma-pages.mjs --section pages --delay 10000",
    "figma:download:rest": "node tools/scripts/download-figma-pages.mjs --delay 10000",
    "figma:download:all": "node tools/scripts/download-figma-pages.mjs --delay 10000",
    "audit:screenshots": "node tools/scripts/playwright-audit.mjs",
    "api:test": "node tools/scripts/api-smoke-test.mjs"
  }
}
