# Figma Personal Access Token
# Create one at: https://help.figma.com/hc/en-us/articles/8085703771159-Manage-personal-access-tokens
# Paste the value into .cursor/mcp.json → env.FIGMA_API_KEY
FIGMA_API_KEY=your_figma_personal_access_token

# Postman API key (for Postman MCP in Cursor)
# Create at: https://postman.postman.co/settings/me/api-keys
# Copy this file to .env and paste your key:
POSTMAN_API_KEY=your_postman_api_key
