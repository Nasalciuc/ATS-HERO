{
  "info": {
    "name": "ATS Hero API",
    "description": "Local API for ATS Hero (Express backend on port 8787). Import this collection in Postman and select the **ATS Hero — Local** environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8787" },
    { "key": "token", "value": "" },
    { "key": "cvId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.environment.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo@ats-hero.test\",\n  \"password\": \"demo123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "GET Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/auth/me"
          }
        }
      ]
    },
    {
      "name": "CV",
      "item": [
        {
          "name": "GET List CVs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/cv"
          }
        },
        {
          "name": "POST Create CV",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.cv?.id) {",
                  "  pm.collectionVariables.set('cvId', json.cv.id);",
                  "  pm.environment.set('cvId', json.cv.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My ATS Resume\",\n  \"data\": {\n    \"personalInfo\": {\n      \"name\": \"David Smith\",\n      \"email\": \"david@example.com\",\n      \"phone\": \"+1 123 456 7890\",\n      \"cityState\": \"Berlin\",\n      \"country\": \"Germany\"\n    },\n    \"summary\": {\n      \"position\": \"UX Designer\",\n      \"valueProposition\": \"Product designer with 5+ years building user-centered experiences.\"\n    },\n    \"skills\": [\"Figma\", \"User Research\", \"Prototyping\"],\n    \"work\": [\n      {\n        \"id\": \"w1\",\n        \"role\": \"Senior UX Designer\",\n        \"company\": \"Acme Corp\",\n        \"startDate\": \"Jan 2022\",\n        \"endDate\": \"Present\",\n        \"current\": true,\n        \"description\": \"Led redesign that increased conversion by 25%.\"\n      }\n    ],\n    \"education\": [\n      {\n        \"id\": \"e1\",\n        \"degree\": \"BSc Design\",\n        \"institution\": \"Design University\",\n        \"startDate\": \"2016\",\n        \"endDate\": \"2020\"\n      }\n    ]\n  }\n}"
            },
            "url": "{{baseUrl}}/api/cv"
          }
        },
        {
          "name": "GET CV by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/cv/{{cvId}}"
          }
        },
        {
          "name": "PUT Update CV",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Resume\",\n  \"data\": {\n    \"skills\": [\"Figma\", \"User Research\", \"Prototyping\", \"Accessibility\"]\n  }\n}"
            },
            "url": "{{baseUrl}}/api/cv/{{cvId}}"
          }
        }
      ]
    },
    {
      "name": "Analysis",
      "item": [
        {
          "name": "POST Score (raw text)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"David Smith UX Designer Berlin david@example.com Experience: Led product design at Acme Corp, increased conversion 25%. Skills: Figma, User Research, Prototyping. Education: BSc Design.\"\n}"
            },
            "url": "{{baseUrl}}/api/score"
          }
        },
        {
          "name": "POST Score (CV data)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cvId\": \"{{cvId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/score"
          }
        },
        {
          "name": "POST Job Fit",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cvText\": \"David Smith UX Designer with Figma, user research, prototyping, accessibility. 5 years experience at Acme Corp.\",\n  \"jobText\": \"We need a UX Designer skilled in Figma, user research, prototyping, and accessibility. Experience with design systems required.\"\n}"
            },
            "url": "{{baseUrl}}/api/jobfit"
          }
        }
      ]
    },
    {
      "name": "Cleanup",
      "item": [
        {
          "name": "DELETE CV",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/cv/{{cvId}}"
          }
        }
      ]
    }
  ]
}
