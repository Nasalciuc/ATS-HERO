    "summary": ["summary", "profile", "objective", "about me", "professional summary"],
    "experience": ["experience", "employment", "work history", "work experience", "professional background"],
    "education": ["education", "academic", "qualifications", "academic background"],
    "skills": ["skills", "technologies", "competencies", "technical skills", "core competencies"]
  },
  "nonstandard_heading_hints": [
    "my journey", "my story", "where i've been", "my career journey",
    "highlights of my impact", "my professional journey", "career highlights"
  ]
}
